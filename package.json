{
  "name": "atenttion-app",
  "version": "1.0.0",
  "description": "Focus tracker with eye tracking, pomodoro, and system monitoring",
  "main": "out/main/index.js",
  "scripts": {
    "dev": "node scripts/dev.js",
    "build": "electron-vite build",
    "preview": "electron-vite preview",
    "dist:win": "npm run build && electron-builder --win",
    "dist:mac": "npm run build && electron-builder --mac",
    "postinstall": "node scripts/setup-models.js && node scripts/setup-sounds.js"
  },
  "dependencies": {
    "@mediapipe/tasks-vision": "^0.10.35",
    "lucide-react": "^0.460.0",
    "recharts": "^2.13.3",
    "zustand": "^5.0.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.20",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "electron-vite": "^2.3.0",
    "playwright-core": "^1.60.0",
    "postcss": "^8.4.49",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "tailwindcss": "^3.4.16",
    "vite": "^5.4.11"
  },
  "build": {
    "appId": "com.atenttion.app",
    "productName": "Atenttion",
    "directories": {
      "output": "dist"
    },
    "files": [
      "out/**/*"
    ],
    "asarUnpack": [
      "out/renderer/models/**",
      "out/renderer/sounds/**"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": {
        "target": "dmg",
        "arch": ["universal"]
      },
      "extendInfo": {
        "NSCameraUsageDescription": "Atenttion uses the camera for real-time eye tracking to detect focus and blink rate.",
        "NSMicrophoneUsageDescription": "Microphone access is not used by Atenttion."
      }
    },
    "publish": [
      {
        "provider": "github",
        "owner": "matiaskelman",
        "repo": "Atenttion_App",
        "draft": false
      }
    ]
  }
}
